# Postgres — Cloud SQL via Cloud Run (Unix socket in prod, TCP in dev)
# Dev:  postgresql://user:password@localhost:5432/elm_cms
# Prod: postgresql://user:password@/elm_cms?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/elm_cms"

# Next.js public URL (used in absolute webhook payloads)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI research — Anthropic Claude
ANTHROPIC_API_KEY=""

# NextAuth — Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
NEXTAUTH_SECRET=""  # generate with: openssl rand -hex 32
NEXTAUTH_URL=""     # e.g. https://elm-intake-429266701915.us-central1.run.app

# Google Cloud Storage bucket for media assets (images downloaded at ingest time)
# Create bucket in Cloud Console → Cloud Storage, then grant Cloud Run SA the Storage Object Admin role
GCS_BUCKET_NAME=""

# Internal API secret for server-to-server calls (e.g. webhook delivery route)
# Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=""
